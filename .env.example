# =============================================================================
# aify-comms — dashboard-driven agent communication and control plane
# =============================================================================
# Copy to .env: cp .env.example .env
# Then: docker compose up -d --build

# -----------------------------------------------------------------------------
# Service Identity
# -----------------------------------------------------------------------------
SERVICE_NAME=aify-comms
SERVICE_VERSION=0.1.0
SERVICE_DESCRIPTION=Dashboard and bridge for spawning, messaging, monitoring, and controlling headless coding agents across connected environments

# -----------------------------------------------------------------------------
# Network / Ports
# -----------------------------------------------------------------------------
# Dashboard: http://localhost:8800/api/v1/dashboard
# API:       http://localhost:8800/api/v1/
SERVICE_PORT=8800

# -----------------------------------------------------------------------------
# Docker
# -----------------------------------------------------------------------------
COMPOSE_PROJECT_NAME=aify-comms
DATA_VOLUME_NAME=aify-comms-data
DATA_VOLUME_EXTERNAL=false
RESTART_POLICY=unless-stopped

# -----------------------------------------------------------------------------
# MCP
# -----------------------------------------------------------------------------
MCP_ENABLED=true
MCP_APP_NAME=claude-code

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LOG_LEVEL=info
LOG_FORMAT=text

# -----------------------------------------------------------------------------
# Resource Limits
# -----------------------------------------------------------------------------
CPU_LIMIT=2
MEMORY_LIMIT=2g

# -----------------------------------------------------------------------------
# Security
# -----------------------------------------------------------------------------
# API key for protecting endpoints (optional — leave empty for no auth)
# When set, all API requests must include X-API-Key header or ?api_key= param
# Dashboard URL will need: http://localhost:8800/api/v1/dashboard?api_key=YOUR_KEY
# MCP client needs: CLAUDE_MCP_API_KEY=YOUR_KEY
# API_KEY=my-secret-key-here
# CORS origins (comma-separated, * for all)
CORS_ORIGINS=*
